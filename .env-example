# SAP connection
SAP_URL=https://your-sap-instance.example.com
SAP_USERNAME=your_username
SAP_PASSWORD=your_password
# Fiori launchpad URL (navigate here after login)
SAP_LAUNCHPAD_URL=

# PostgreSQL (local testing)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/al_ghanem_extraction

# Scraper options
HEADLESS=false
SELENIUM_TIMEOUT=30
# Optional: path to local chromedriver.exe (skips online download; recommended on corporate networks)
# CHROMEDRIVER_PATH=C:\Users\you\.wdm\drivers\chromedriver\win64\149.0.7827.155\chromedriver-win64\chromedriver.exe
# Invitations always use Document Date = Today in SAP.
# 0 = fetch all invitations for Today. Set to 2 for a short test run.
SAP_MAX_INVITATIONS=0
SAP_SKIP_FIRST_INQUIRY=false
# Short pause (ms) after a page-ready check, before the next action
SAP_SETTLE_MS=300
# Optional: direct Fiori app URL (skips launchpad tile search)
# SAP_MANAGE_SALES_ENQUIRIES_URL=

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# API server
API_HOST=127.0.0.1
API_PORT=8000
