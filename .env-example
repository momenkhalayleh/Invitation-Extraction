# SAP connection
SAP_URL=https://your-sap-instance.example.com
SAP_USERNAME=your_username
SAP_PASSWORD=your_password
# Fiori launchpad URL (navigate here after login)
SAP_LAUNCHPAD_URL=

# PostgreSQL (local testing)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/al_ghanem_extraction

# Scraper options
HEADLESS=true
SELENIUM_TIMEOUT=30
# Document Date picker option: "From / To" (range), or "Today" / "Yesterday" / "Tomorrow"
SAP_DATE_OPTION=From / To
# Test mode: process only 1 inquiry. Set SAP_SKIP_FIRST_INQUIRY=true to skip a locked first row.
SAP_MAX_INVITATIONS=1
SAP_SKIP_FIRST_INQUIRY=false
# Optional: direct Fiori app URL (skips launchpad tile search)
# SAP_MANAGE_SALES_ENQUIRIES_URL=
SCRAPE_DATE_FROM=2026-01-01
SCRAPE_DATE_TO=2026-01-31

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
